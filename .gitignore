__pycache__/
*.pyc
.venv/
dist/
build/
*.egg-info/
.DS_Store

# private / sensitive material — never push
*passphrase*.txt
*passphrase*.json
hutcheson_contract.docx
*_contract.docx
*_contract.pdf
github_token.txt
*.token
.env
.env.*
# Session handoff docs — these tend to embed live API keys and
# session-specific notes. Treat as local-only by default. If you need
# to share one publicly, scrub it to a separate path first.
CLAUDE_CODE_HANDOFF.md
CLAUDE_CODE_HANDOFF_*.md

# The local helper scripts no longer embed the Cloudflare tunnel token.
# They read it from C:\Concordance\tunnel.token at runtime, which is
# outside the repo. *.token above already keeps any in-repo token files
# from being committed by accident.

# frozen distribution snapshot — kept locally, not tracked
concordance_engine-1.0.4/

# pytest cache
.pytest_cache/

# Claude Code local settings
.claude/

# Local audit working doc � not for the public repo
GAP_PLAN.md

# Local audit working doc - not for the public repo
GAP_PLAN.md
# Layer 0 source data — large files, built locally via build_concordance.py / fetch_sources.py
lw/00_source/original/
lw/00_source/web/

# Pytest cache directories (non-standard names)
pytest-cache-files-*/

# Local working notes
WORKING_STATE.md
HARVEST_FINDINGS_*.md

# Runtime audit log — written by api/ledger.py at runtime. The
# canonical precedent store is lw/ledger/; this top-level jsonl is
# transient runtime state that shouldn't pollute the repo.
ledger.jsonl

# Run logs from evaluation harnesses
lw/09_evaluation/run.log
**/run.log

# Runtime stores — written by the engine at runtime (journal entries,
# keeping log, quarantine packets). Each operator's local kingdom is
# theirs; nothing here belongs in the repo.
lw/journal/
lw/keeping/
lw/quarantine/

# Local seed-runner working files — log output, fingerprint state.
# The state files are operator-local (each machine has different
# fingerprints); the logs are pure transcripts. None belong in the repo.
scripts/seed/seed_*.log
scripts/seed/seed_*.log.err
scripts/seed/seed_gen_run.log
scripts/seed/seed_err.log
scripts/seed/seed_run*.log
scripts/seed/seed_w*_run.log
scripts/seed/seed_w*_err.log
scripts/seed/seed_state_w*.json
scripts/seed/seed_gen_state.json

# Local CAS object store + case store DB — operator-local runtime artifacts
case_store.db
data/cas/
data/grid_connections.jsonl

# Local handoff doc — embeds session-specific notes
HANDOFF_OPUS.md

# Miner output — local-only, never committed
data/miner/

# Visit log — privacy-respecting access counter, local-only
data/visits/

# Community participation state — contributor profiles + activity log
# are operator-side state, not source. Per-instance.
data/contributors/
data/activity/

# Axis extensions — additive layer applied at module load. Operator-
# named axes land here. Treat as per-instance configuration; commit
# to a fresh location only when you're ready to canonicalize.
data/grid/

# Inbox + intake + quarantine — operator-only mailbox, working queue,
# and trash. Contains user-submitted text and contact messages (may
# have email addresses, names, etc). Never committed to a public repo.
data/inbox/
data/intake/
data/quarantine/
