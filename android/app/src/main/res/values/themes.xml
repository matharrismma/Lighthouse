<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Concordance dark theme — edge-to-edge, no system chrome -->
    <style name="Theme.Concordance" parent="android:Theme.Material.NoTitleBar">
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>
</resources>
